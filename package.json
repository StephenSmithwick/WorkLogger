{
  "name": "WorkLogger",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db": "wrangler secret put DATABASE_URL"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@neondatabase/serverless": "^1.1.0",
    "@thisbeyond/solid-select": "^0.16.0",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.30",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@types/node": "^26.1.1",
    "drizzle-kit": "1.0.0-rc.4",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.1",
    "vite": "^6.4.3",
    "vite-plugin-solid": "^2.11.12",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.110.0"
  }
}
